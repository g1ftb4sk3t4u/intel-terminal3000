# Intel Terminal 1000 Environment Configuration

# App Settings
DEBUG=false
SECRET_KEY=change-this-in-production-please

# Data Source Toggles
RSS_ENABLED=true
GDELT_ENABLED=true
REDDIT_ENABLED=false
BLUESKY_ENABLED=false
TELEGRAM_ENABLED=false

# Fetch Intervals (seconds)
RSS_FETCH_INTERVAL=300
GDELT_FETCH_INTERVAL=900

# Reddit (optional - works without auth for public data)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=IntelTerminal1000/1.0

# Bluesky (optional - works without auth for public feeds)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Telegram (requires API credentials for full functionality)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# AI Triage Settings
# Options: keyword | ollama | openai | claude | manual
TRIAGE_METHOD=keyword

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI API (optional)
OPENAI_API_KEY=

 # Anthropic Claude API (optional)
ANTHROPIC_API_KEY=
# Claude model (optional, e.g. claude-3-opus-20240229 for Opus 4.6, claude-3-haiku-20240307 for Haiku)
CLAUDE_MODEL=claude-3-opus-20240229

# Geolocation
GEOCODE_ENABLED=true
GEOCODE_CACHE_DAYS=30

# Discord Notifications (optional)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# WebSocket
WS_HEARTBEAT_INTERVAL=30
